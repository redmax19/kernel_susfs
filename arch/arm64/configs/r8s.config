# Config for r8s

CONFIG_MODEL_R8S=y

# RAM configuration
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y
# CONFIG_TRANSPARENT_HUGEPAGE_MADVISE is not set
CONFIG_PROCESS_RECLAIM_IGNORE_ALL_TYPE=y
CONFIG_VM_MAX_READAHEAD_KB=128
CONFIG_HUGEPAGE_POOL=y
# CONFIG_HUGEPAGE_POOL_DEBUG is not set
CONFIG_HUGEPAGE_POOL_ALLOW_ALL=y

# Modem
CONFIG_MHI_BUS=y
CONFIG_MHI_DEBUG=y
CONFIG_MHI_UCI=y
CONFIG_QRTR=y
CONFIG_QRTR_MHI=y

# WiFi / BT
# CONFIG_BROADCOM_WIFI is not set
# CONFIG_BCM4375 is not set
# CONFIG_BT_BCM43XX is not set
CONFIG_QCA_CLD_WLAN=y
CONFIG_MSM_BT_POWER=y
CONFIG_WIRELESS_EXT=y
CONFIG_WEXT_PRIV=y
CONFIG_CNSS2=y
CONFIG_CNSS2_QMI=y
CONFIG_CNSS_QCA6390=y
CONFIG_CNSS_GENL=y
CONFIG_WCNSS_MEM_PRE_ALLOC=y
CONFIG_BUS_AUTO_SUSPEND=y
CONFIG_QCOM_QMI_HELPERS=y

# NFC
# CONFIG_ESE_COLDRESET is not set

# Touchscreen
# CONFIG_TOUCHSCREEN_SEC_TS_Y79A is not set
# CONFIG_SUPPORT_TS_240HZ is not set
CONFIG_TOUCHSCREEN_ZINITIX_ZT7650=y
CONFIG_TOUCHSCREEN_STM_FTS5CU56A=y

# Camera
# CONFIG_CAMERA_HST_V01 is not set
CONFIG_CAMERA_RST_V08=y
# CONFIG_CAMERA_CIS_3J1_OBJ is not set
# CONFIG_CAMERA_CIS_GW2_OBJ is not set
# CONFIG_CAMERA_CIS_2LA_OBJ is not set
# CONFIG_CAMERA_FLASH_S2MPB02_OBJ is not set
CONFIG_CAMERA_CIS_IMX616_OBJ=y
CONFIG_CAMERA_CIS_HI847_OBJ=y
CONFIG_CAMERA_CIS_3L6_OBJ=y
CONFIG_CAMERA_FLASH_RT8547_OBJ=y

# Display
# CONFIG_SUPPORT_ACCESSIBILITY is not set
# CONFIG_EXYNOS_DECON_LCD_COPR is not set
# CONFIG_SUPPORT_DSU is not set
# CONFIG_SUPPORT_HMD is not set
CONFIG_EXYNOS_DOZE_FIRST_FRAME_BLACK=y
# CONFIG_EXTEND_LIVE_CLOCK is not set
# CONFIG_SUPPORT_DISPLAY_PROFILER is not set
# CONFIG_SUPPORT_DDI_FLASH is not set
# CONFIG_SUPPORT_POC_FLASH is not set
# CONFIG_SUPPORT_MAFPC is not set
# CONFIG_SUPPORT_DIM_FLASH is not set
# CONFIG_SUPPORT_GRAM_CHECKSUM is not set
# CONFIG_SUPPORT_CCD_TEST is not set
# CONFIG_PANEL_BACKLIGHT_PAC_3_0 is not set
# CONFIG_SUPPORT_POC_SPI is not set
# CONFIG_PANEL_VRR_BRIDGE is not set
# CONFIG_EXYNOS_DECON_LCD_S6E3HAB is not set
CONFIG_SUPPORT_FAST_DISCHARGE=y
CONFIG_SUPPORT_MASK_LAYER=y
CONFIG_PANEL_DECON_BOARD=y
CONFIG_PANEL_MAGNA_DDI=y
CONFIG_EXYNOS_DECON_LCD_EA8076=y
CONFIG_EXYNOS_DECON_LCD_EA8079=y
CONFIG_EXYNOS_DECON_LCD_S6E3FC3=y
# CONFIG_ONEUI7_WORKAROUND is not set

# Battery / Charger
# CONFIG_PD_CHARGER_HV_DISABLE is not set
CONFIG_TX_5V_DISABLE=y

# Sensors
# CONFIG_SENSORS_SSP_LSM6DSO is not set
# CONFIG_SENSORS_SSP_MAGNETIC_COMMON is not set
# CONFIG_SENSORS_SSP_LPS22H is not set
# CONFIG_SENSORS_SSP_TMD4907 is not set
# CONFIG_SENSORS_SSP_PROX_AUTOCAL_AMS is not set
# CONFIG_SENSORS_SSP_LIGHT_COLORID is not set
# CONFIG_SENSORS_SX9360 is not set
CONFIG_SENSORS_A96T3X6=y
CONFIG_SENSORS_FW_VENDOR=y
CONFIG_SENSORS_A96T3X6_CRC_CHECK=y
CONFIG_SENSORS_A96T3X6_BLOCK_SAR_ONLY=y
# CONFIG_SENSORS_SSP_PICASSO is not set
CONFIG_SENSORS_SSP_R8=y
CONFIG_SENSORS_SABC=y
CONFIG_SENSORS_DYNAMIC_SENSORLIST=y
CONFIG_SENSORS_ICM42632M=y
CONFIG_SENSORS_LSM6DSO=y
CONFIG_SENSORS_TMD4907=y
CONFIG_SENSORS_STK31610=y
CONFIG_SENSORS_AK09918C=y
CONFIG_SENSORS_LPS22H=y
CONFIG_SENSORS_LPS25H=y
CONFIG_SENSORS_GW9558X=y
# CONFIG_SENSORS_QBT2000 is not set

# Haptic
CONFIG_MOTOR_DRV_MAX77705=y
CONFIG_SEC_HAPTIC=y
# CONFIG_MOTOR_CS40L2X is not set

# LED
CONFIG_LEDS_S2MPB02 is not set
CONFIG_LEDS_RT8547=y

# Misc
CONFIG_NAD_55=y
CONFIG_SEC_SUPPORT_MOTTOTEST_WITH_ACT=y
CONFIG_SEC_BPS_INFO_ADD=y
CONFIG_MST_SUPPORT_GPIO=y

# Kernel configurations for full DroidSpaces support
# Copyright (C) 2026 ravindu644 <droidcasts@protonmail.com>

# IPC mechanisms
CONFIG_SYSCTL=y
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y

# Core namespace support
CONFIG_NAMESPACES=y
CONFIG_PID_NS=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y

# Seccomp support
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# Control groups support
CONFIG_CGROUPS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_PIDS=y
CONFIG_MEMCG=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_NET_PRIO=y

# Device filesystem support
CONFIG_DEVTMPFS=y

# Overlay filesystem support (required for volatile mode)
CONFIG_OVERLAY_FS=y

# Firmware loading support
CONFIG_FW_LOADER=y
CONFIG_FW_LOADER_USER_HELPER=y
CONFIG_FW_LOADER_COMPRESS=y

# Droidspaces Network Isolation Support - NAT/none modes
CONFIG_NET_NS=y
CONFIG_VETH=y
CONFIG_BRIDGE=y
CONFIG_NETFILTER=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_NF_NAT=y
CONFIG_NF_TABLES=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_NETFILTER_XT_TARGET_TCPMSS=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NF_CONNTRACK_NETLINK=y
CONFIG_NF_NAT_REDIRECT=y
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y

# legacy compat
CONFIG_NF_CONNTRACK_IPV4=y
CONFIG_NF_NAT_IPV4=y
CONFIG_IP_NF_NAT=y

# Disable this on older kernels to make internet work
CONFIG_ANDROID_PARANOID_NETWORK=n

# UFW & FAIL2BAN CORE
CONFIG_NETFILTER_XT_MATCH_COMMENT=y
CONFIG_NETFILTER_XT_MATCH_STATE=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_MULTIPORT=y
CONFIG_NETFILTER_XT_MATCH_HL=y
CONFIG_NETFILTER_XT_TARGET_REJECT=y
CONFIG_IP_NF_TARGET_REJECT=y
CONFIG_NETFILTER_XT_TARGET_LOG=y
CONFIG_IP_NF_TARGET_ULOG=y
CONFIG_NETFILTER_XT_MATCH_RECENT=y
CONFIG_NETFILTER_XT_MATCH_LIMIT=y
CONFIG_NETFILTER_XT_MATCH_HASHLIMIT=y
CONFIG_NETFILTER_XT_MATCH_OWNER=y
CONFIG_NETFILTER_XT_MATCH_PKTTYPE=y
CONFIG_NETFILTER_XT_MATCH_MARK=y
CONFIG_NETFILTER_XT_TARGET_MARK=y
CONFIG_IP_SET=y
CONFIG_IP_SET_HASH_IP=y
CONFIG_IP_SET_HASH_NET=y
CONFIG_NETFILTER_XT_SET=y
CONFIG_NETFILTER_NETLINK_QUEUE=y
CONFIG_NETFILTER_NETLINK_LOG=y
CONFIG_NETFILTER_XT_TARGET_NFLOG=y
